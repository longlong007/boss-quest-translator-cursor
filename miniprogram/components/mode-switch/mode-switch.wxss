.mode-switch {
  display: flex;
  background: rgba(0, 0, 0, 0.25);
  border-radius: 16rpx;
  padding: 6rpx;
  margin: 32rpx 0 24rpx;
}

.mode-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.55);
  border-radius: 12rpx;
  transition: all 0.2s;
}

.mode-item.active {
  background: rgba(233, 69, 96, 0.9);
  color: #fff;
  font-weight: 600;
}
