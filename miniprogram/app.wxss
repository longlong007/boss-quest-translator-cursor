page {
  min-height: 100vh;
  background: linear-gradient(165deg, #16213e 0%, #1a1a2e 45%, #0f3460 100%);
  color: #e8e8e8;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB',
    'Microsoft YaHei', sans-serif;
  box-sizing: border-box;
}

.container {
  padding: 32rpx 40rpx 48rpx;
  box-sizing: border-box;
}

.btn-primary {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #e94560 0%, #c73e54 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  margin-top: 32rpx;
}

.btn-primary[disabled] {
  opacity: 0.55;
  background: #666;
}

.btn-secondary {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.12);
  color: #fff;
  border: 1rpx solid rgba(255, 255, 255, 0.25);
}

.card {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 26rpx;
  color: #e94560;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.card-body {
  font-size: 30rpx;
  line-height: 1.65;
  color: #f0f0f0;
  white-space: pre-wrap;
  word-break: break-word;
}

.disclaimer {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.45);
  text-align: center;
  margin-top: 40rpx;
  line-height: 1.5;
  padding: 0 16rpx;
}
