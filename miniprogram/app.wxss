page {
  min-height: 100vh;
  background: linear-gradient(180deg, #fff9eb 0%, #ffe8c8 45%, #ffd4a8 100%);
  color: #3d3d3d;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB',
    'Microsoft YaHei', sans-serif;
  box-sizing: border-box;
}

.container {
  padding: 24rpx 36rpx 56rpx;
  box-sizing: border-box;
}

/* 小程序 button 默认带 padding/边框，用 flex 保证文字居中 */
.btn-primary {
  width: 100% !important;
  height: 96rpx;
  margin: 32rpx 0 0;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  background: linear-gradient(135deg, #ff9f43 0%, #ff6b35 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  box-shadow: 0 12rpx 28rpx rgba(255, 107, 53, 0.35);
}

.btn-primary::after {
  border: none;
}

.btn-primary[disabled] {
  opacity: 0.55;
  background: #ccc;
  box-shadow: none;
}

.btn-secondary {
  flex: 1;
  height: 88rpx;
  margin: 0;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 44rpx;
  background: #fff;
  color: #ff6b35;
  border: 2rpx solid #ffb347;
  box-shadow: 0 6rpx 16rpx rgba(255, 159, 67, 0.15);
}

.btn-secondary::after {
  border: none;
}

.card {
  background: #fff;
  border-radius: 28rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 140, 66, 0.12);
  border: 2rpx solid rgba(255, 200, 120, 0.35);
}

.card-title {
  font-size: 26rpx;
  color: #ff8c42;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.card-body {
  font-size: 30rpx;
  line-height: 1.65;
  color: #4a4a4a;
  white-space: pre-wrap;
  word-break: break-word;
}

.disclaimer {
  font-size: 22rpx;
  color: #a08060;
  text-align: center;
  margin-top: 36rpx;
  line-height: 1.55;
  padding: 0 16rpx;
}
