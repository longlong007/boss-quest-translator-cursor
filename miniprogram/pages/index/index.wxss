.page-index .header {
  text-align: center;
  padding: 24rpx 0 8rpx;
}

.page-index .title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 2rpx;
}

.page-index .slogan {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.55);
  margin-top: 12rpx;
}

.input-wrap {
  position: relative;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  padding: 24rpx 28rpx 48rpx;
  min-height: 240rpx;
}

.input-area {
  width: 100%;
  min-height: 200rpx;
  font-size: 30rpx;
  line-height: 1.6;
  color: #f5f5f5;
}

.placeholder {
  color: rgba(255, 255, 255, 0.35);
}

.char-count {
  position: absolute;
  right: 28rpx;
  bottom: 16rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
}

.examples-section {
  margin-top: 28rpx;
}

.examples-title {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 16rpx;
}

.examples-list {
  display: flex;
  flex-wrap: wrap;
  margin: -8rpx;
}

.example-chip {
  margin: 8rpx;
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  border-radius: 32rpx;
  line-height: 1.4;
}

.example-chip:active {
  background: rgba(233, 69, 96, 0.25);
  border-color: rgba(233, 69, 96, 0.5);
}
