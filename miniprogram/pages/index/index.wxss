.page-index .header {
  text-align: center;
  padding: 24rpx 0 8rpx;
}

.page-index .title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 2rpx;
}

.page-index .slogan {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.55);
  margin-top: 12rpx;
}

.input-wrap {
  position: relative;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  padding: 24rpx 28rpx 48rpx;
  min-height: 240rpx;
}

.input-area {
  width: 100%;
  min-height: 200rpx;
  font-size: 30rpx;
  line-height: 1.6;
  color: #f5f5f5;
}

.placeholder {
  color: rgba(255, 255, 255, 0.35);
}

.char-count {
  position: absolute;
  right: 28rpx;
  bottom: 16rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
}
