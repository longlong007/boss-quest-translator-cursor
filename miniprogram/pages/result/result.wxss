.page-result {
  min-height: 100vh;
}

.result-header {
  margin-bottom: 8rpx;
}

.page-result .mode-tag {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  font-weight: 600;
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
}

.tag-icon {
  font-size: 30rpx;
}

.mode-tag.serious {
  background: linear-gradient(135deg, #dfe6ff, #c8e0ff);
  color: #0984e3;
  border: 2rpx solid #a8d4ff;
}

.mode-tag.fun {
  background: linear-gradient(135deg, #ffe0f0, #ffc8e0);
  color: #e84393;
  border: 2rpx solid #ffb8d9;
}

.quote-card {
  background: linear-gradient(135deg, #fff9f0, #fff);
}

.quote-card .quote {
  font-style: italic;
  color: #555;
  font-size: 30rpx;
}

.card-fun .card-title {
  color: #e84393;
}

.highlight {
  border-width: 2rpx;
}

.highlight-serious {
  border-color: #74b9ff;
  background: linear-gradient(135deg, #f0f7ff, #fff);
}

.highlight-serious .card-title {
  color: #0984e3;
}

.highlight-fun {
  border-color: #fd79a8;
  background: linear-gradient(135deg, #fff5f9, #fff);
}

.highlight-fun .card-title {
  color: #e84393;
}

.actions {
  display: flex;
  gap: 24rpx;
  margin-top: 20rpx;
}
