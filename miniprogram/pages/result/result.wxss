.page-result .mode-tag {
  display: inline-block;
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
}

.mode-tag.serious {
  background: rgba(15, 52, 96, 0.8);
  color: #7eb8da;
  border: 1rpx solid rgba(126, 184, 218, 0.4);
}

.mode-tag.fun {
  background: rgba(233, 69, 96, 0.25);
  color: #ff8fa3;
  border: 1rpx solid rgba(233, 69, 96, 0.5);
}

.quote-card .quote {
  font-style: italic;
  color: rgba(255, 255, 255, 0.85);
}

.card.highlight {
  border-color: rgba(233, 69, 96, 0.35);
  background: rgba(233, 69, 96, 0.08);
}

.actions {
  display: flex;
  gap: 24rpx;
  margin-top: 16rpx;
}

.actions .btn-secondary {
  margin: 0;
  padding: 0;
}
